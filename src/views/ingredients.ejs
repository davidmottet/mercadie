<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="/output.css" rel="stylesheet">
    <title>Liste des Ingrédients</title>
</head>
<body class="bg-gray-100 dark:bg-gray-900">
    <div class="container mx-auto py-10">
        <h1 class="text-3xl font-bold text-center text-gray-800 dark:text-white mb-8">Liste des Ingrédients</h1>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            <% ingredients.forEach(ingredient => { %>
                <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md p-6">
                    <h2 class="text-xl font-semibold text-gray-900 dark:text-white"><%= ingredient.displayName || ingredient.name %></h2>
                    <p class="text-gray-700 dark:text-gray-300"><strong>Nom Pluriel:</strong> <%= ingredient.displayPlural || 'N/A' %></p>
                    <p class="text-gray-700 dark:text-gray-300"><strong>Congelé ou en conserve:</strong> <%= ingredient.frozenOrCanned ? 'Oui' : 'Non' %></p>
                    <p class="text-gray-700 dark:text-gray-300"><strong>Saisons:</strong> <%= ingredient.seasons.join(', ') %></p>
                    <p class="text-gray-700 dark:text-gray-300"><strong>Quantité:</strong> <%= ingredient.quantity %></p>
                    <p class="text-gray-700 dark:text-gray-300"><strong>Unité de mesure:</strong> <%= ingredient.measurementUnit.name %></p>
                    <p class="text-gray-700 dark:text-gray-300"><strong>Poids brut:</strong> <%= ingredient.grossWeight %></p>
                </div>
            <% }) %>
        </div>
    </div>
</body>
</html>