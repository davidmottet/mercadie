<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Planifiez vos repas et suivez votre nutrition avec Mercadie. Découvrez une interface moderne et intuitive pour des menus équilibrés et personnalisés." />
    <link href="./output.css" rel="stylesheet">
    <title>Mercadie - Votre Assistant Nutritionnel Moderne</title>
  </head>
  <body class="bg-gray-50 dark:bg-gray-900 min-h-screen text-gray-800 dark:text-white">
    <%- include('partials/header') %>


    <!-- Hero Section -->
    <section id="accueil" class="bg-gradient-to-r from-blue-500 to-blue-600 text-white py-20 mt-20">
      <div class="container mx-auto px-6 text-center">
        <h1 class="text-4xl md:text-5xl font-bold mb-6">Planifiez vos repas &amp; suivez votre nutrition</h1>
        <p class="text-lg md:text-xl mb-8">
          Avec Mercadie, créez des menus équilibrés, générez automatiquement vos listes de courses et profitez d'une expérience utilisateur moderne et intuitive.
        </p>
        <a href="#contact" class="bg-white text-blue-500 font-semibold px-8 py-3 rounded-full shadow-lg hover:bg-gray-100 transition duration-300">Essayez Gratuitement</a>
      </div>
    </section>

    <!-- Features Section -->
    <section id="features" class="py-20">
      <div class="container mx-auto px-6">
        <h2 class="text-3xl font-bold text-center mb-12">Fonctionnalités</h2>
        <div class="grid gap-12 md:grid-cols-3">
          <!-- Feature 1 -->
          <div class="bg-white dark:bg-gray-800 p-8 rounded-xl shadow-md hover:shadow-xl transition duration-300">
            <div class="mb-4">
              <div class="w-16 h-16 mx-auto bg-blue-100 dark:bg-blue-900 rounded-full flex items-center justify-center">
                <i class="fas fa-calendar text-2xl text-blue-500"></i>
              </div>
            </div>
            <h3 class="text-xl font-semibold mb-2 text-center">Planification de Repas</h3>
            <p class="text-gray-600 dark:text-gray-300 text-center">
              Créez des menus personnalisés et équilibrés pour toute la semaine en quelques clics.
            </p>
          </div>
          <!-- Feature 2 -->
          <div class="bg-white dark:bg-gray-800 p-8 rounded-xl shadow-md hover:shadow-xl transition duration-300">
            <div class="mb-4">
              <div class="w-16 h-16 mx-auto bg-blue-100 dark:bg-blue-900 rounded-full flex items-center justify-center">
                <i class="fas fa-shopping-cart text-2xl text-blue-500"></i>
              </div>
            </div>
            <h3 class="text-xl font-semibold mb-2 text-center">Liste de Courses Automatique</h3>
            <p class="text-gray-600 dark:text-gray-300 text-center">
              Générez automatiquement une liste de courses basée sur vos recettes et menus planifiés.
            </p>
          </div>
          <!-- Feature 3 -->
          <div class="bg-white dark:bg-gray-800 p-8 rounded-xl shadow-md hover:shadow-xl transition duration-300">
            <div class="mb-4">
              <div class="w-16 h-16 mx-auto bg-blue-100 dark:bg-blue-900 rounded-full flex items-center justify-center">
                <i class="fas fa-chart-pie text-2xl text-blue-500"></i>
              </div>
            </div>
            <h3 class="text-xl font-semibold mb-2 text-center">Suivi Nutritionnel</h3>
            <p class="text-gray-600 dark:text-gray-300 text-center">
              Analysez les apports nutritionnels de vos repas pour atteindre vos objectifs santé.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- About Section -->
    <section id="a-propos" class="bg-gray-100 dark:bg-gray-800 py-20">
      <div class="container mx-auto px-6">
        <h2 class="text-3xl font-bold text-center mb-8">À propos de Mercadie</h2>
        <div class="max-w-3xl mx-auto text-center">
          <p class="text-gray-700 dark:text-gray-300 mb-4">
            Mercadie est une solution web innovante pour planifier vos repas de façon saine et personnalisée. Inspiré par les meilleures pratiques de l'industrie, notre application vous aide à organiser vos menus, suivre votre nutrition et simplifier vos courses.
          </p>
          <p class="text-gray-700 dark:text-gray-300">
            Notre interface moderne et intuitive rend la planification de repas plus simple que jamais.
          </p>
        </div>
      </div>
    </section>

    <!-- Call-to-Action Section -->
    <section id="contact" class="py-20 bg-blue-500 text-white">
      <div class="container mx-auto px-6 text-center">
        <h2 class="text-3xl font-bold mb-6">Prêt à changer votre façon de manger ?</h2>
        <p class="mb-8 text-lg">
          Rejoignez dès maintenant Mercadie et transformez votre alimentation en un véritable jeu d'enfant.
        </p>
        <a href="#" class="bg-white text-blue-500 font-semibold px-8 py-3 rounded-full shadow-lg hover:bg-gray-100 transition duration-300">Commencer Gratuitement</a>
      </div>
    </section>

    <!-- Footer -->
    <footer class="bg-gray-800 text-gray-300 py-8">
      <div class="container mx-auto px-6 text-center">
        <p>&copy; 2024 Mercadie. Tous droits réservés.</p>
        <div class="mt-4 space-x-4">
          <a href="#" class="hover:text-white transition">Mentions légales</a>
          <a href="#" class="hover:text-white transition">Politique de confidentialité</a>
          <a href="#" class="hover:text-white transition">Contact</a>
        </div>
      </div>
    </footer>
  </body>
</html> 