<!-- public/index.html -->
<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <link href="./output.css" rel="stylesheet">
        <title>Sign in</title>
    </head>
    <body class="bg-white">
        <%- include('partials/header', { user, order }) %>

        <main class="h-screen w-full banner">
            <div class="flex flex-col justify-center items-center h-screen">
                <div class="flex flex-grow">
                    <img class="w-36 cursor-pointer" src="./logo.png" alt="logo" onclick="window.location.href='/'" />
                </div>
                <form class="bg-white w-96 mt-6 p-4 rounded-lg shadow-lg" onSubmit={handleSubmit}>
                    <div class="flex flex-col space-y-6">
                        
                    </div>
                    <Button text="Sign In" />
                    <Link to="/signup">
                        <p class="text-base text-primary text-center my-6 hover:underline">Need an account ?</p>
                    </Link>

                    <GoogleSignIn text="Sign In With Google" />
                </form>
            </div>
        </main>

        <%- include('partials/footer/footer') %>
    </body>
</html>


